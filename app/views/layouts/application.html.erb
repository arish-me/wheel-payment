<!DOCTYPE html>
<html>
  <head>
    <title>Wheel Payment - Escrow Platform</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <% if false %>
      <%= javascript_importmap_tags %>
    <% end %>
  </head>

  <body class="bg-gray-50">
    <!-- Navigation -->
    <nav class="bg-white shadow-sm border-b border-gray-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16">
          <div class="flex">
            <div class="flex-shrink-0 flex items-center">
              <h1 class="text-xl font-bold text-gray-900">Wheel Payment</h1>
            </div>
          </div>

          <div class="flex items-center">
            <% if user_signed_in? %>
              <div class="ml-3 relative">
                <div class="flex items-center space-x-4">
                  <span class="text-sm text-gray-700">
                    Welcome, <%= current_user.email %>
                  </span>
                  <%= link_to "Dashboard", dashboard_path, class: "text-sm text-blue-600 hover:text-blue-800" %>
                  <%= link_to "Projects", projects_path, class: "text-sm text-blue-600 hover:text-blue-800" %>
                  <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "text-sm text-red-600 hover:text-red-800" %>
                </div>
              </div>
            <% else %>
              <div class="flex items-center space-x-4">
                <%= link_to "Sign in", new_user_session_path, class: "text-sm text-blue-600 hover:text-blue-800" %>
                <%= link_to "Sign up", new_user_registration_path, class: "bg-blue-600 text-white px-4 py-2 rounded-md text-sm font-medium hover:bg-blue-700" %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </nav>

    <!-- Flash Messages -->
    <% if notice %>
      <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded relative mb-4" role="alert">
        <span class="block sm:inline"><%= notice %></span>
      </div>
    <% end %>

    <% if alert %>
      <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded relative mb-4" role="alert">
        <span class="block sm:inline"><%= alert %></span>
      </div>
    <% end %>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto py-6 sm:px-6 lg:px-8">
      <%= yield %>
    </main>
  </body>
</html>
