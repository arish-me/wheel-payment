<div class="bg-white shadow rounded-lg">
  <div class="px-4 py-5 sm:p-6">
    <h3 class="text-lg leading-6 font-medium text-gray-900">
      Admin Dashboard
    </h3>
    <p class="mt-1 text-sm text-gray-500">
      Platform overview and recent activity.
    </p>
  </div>
</div>

<!-- Statistics Grid -->
<div class="mt-8 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
  <!-- Total Projects -->
  <div class="bg-white overflow-hidden shadow rounded-lg">
    <div class="p-5">
      <div class="flex items-center">
        <div class="flex-shrink-0">
          <svg class="h-6 w-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
          </svg>
        </div>
        <div class="ml-5 w-0 flex-1">
          <dl>
            <dt class="text-sm font-medium text-gray-500 truncate">Total Projects</dt>
            <dd class="text-lg font-medium text-gray-900"><%= @total_projects %></dd>
          </dl>
        </div>
      </div>
    </div>
  </div>

  <!-- Total Users -->
  <div class="bg-white overflow-hidden shadow rounded-lg">
    <div class="p-5">
      <div class="flex items-center">
        <div class="flex-shrink-0">
          <svg class="h-6 w-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z" />
          </svg>
        </div>
        <div class="ml-5 w-0 flex-1">
          <dl>
            <dt class="text-sm font-medium text-gray-500 truncate">Total Users</dt>
            <dd class="text-lg font-medium text-gray-900"><%= @total_users %></dd>
          </dl>
        </div>
      </div>
    </div>
  </div>

  <!-- Total Transactions -->
  <div class="bg-white overflow-hidden shadow rounded-lg">
    <div class="p-5">
      <div class="flex items-center">
        <div class="flex-shrink-0">
          <svg class="h-6 w-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <div class="ml-5 w-0 flex-1">
          <dl>
            <dt class="text-sm font-medium text-gray-500 truncate">Transactions</dt>
            <dd class="text-lg font-medium text-gray-900"><%= @total_transactions %></dd>
          </dl>
        </div>
      </div>
    </div>
  </div>

  <!-- Total in Escrow -->
  <div class="bg-white overflow-hidden shadow rounded-lg">
    <div class="p-5">
      <div class="flex items-center">
        <div class="flex-shrink-0">
          <svg class="h-6 w-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1" />
          </svg>
        </div>
        <div class="ml-5 w-0 flex-1">
          <dl>
            <dt class="text-sm font-medium text-gray-500 truncate">In Escrow</dt>
            <dd class="text-lg font-medium text-gray-900">$<%= number_with_precision(@total_in_escrow / 100.0, precision: 2) %></dd>
          </dl>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- User and Project Stats -->
<div class="mt-8 grid grid-cols-1 gap-6 lg:grid-cols-2">
  <!-- User Statistics -->
  <div class="bg-white shadow rounded-lg">
    <div class="px-4 py-5 sm:p-6">
      <h4 class="text-lg font-medium text-gray-900 mb-4">User Statistics</h4>
      <div class="space-y-3">
        <div class="flex justify-between">
          <span class="text-sm text-gray-500">Clients</span>
          <span class="text-sm font-medium text-gray-900"><%= @user_stats[:clients] %></span>
        </div>
        <div class="flex justify-between">
          <span class="text-sm text-gray-500">Developers</span>
          <span class="text-sm font-medium text-gray-900"><%= @user_stats[:developers] %></span>
        </div>
        <div class="flex justify-between">
          <span class="text-sm text-gray-500">Admins</span>
          <span class="text-sm font-medium text-gray-900"><%= @user_stats[:admins] %></span>
        </div>
      </div>
    </div>
  </div>

  <!-- Project Statistics -->
  <div class="bg-white shadow rounded-lg">
    <div class="px-4 py-5 sm:p-6">
      <h4 class="text-lg font-medium text-gray-900 mb-4">Project Statistics</h4>
      <div class="space-y-3">
        <div class="flex justify-between">
          <span class="text-sm text-gray-500">Draft</span>
          <span class="text-sm font-medium text-gray-900"><%= @project_stats[:draft] %></span>
        </div>
        <div class="flex justify-between">
          <span class="text-sm text-gray-500">Active</span>
          <span class="text-sm font-medium text-gray-900"><%= @project_stats[:active] %></span>
        </div>
        <div class="flex justify-between">
          <span class="text-sm text-gray-500">Completed</span>
          <span class="text-sm font-medium text-gray-900"><%= @project_stats[:completed] %></span>
        </div>
        <div class="flex justify-between">
          <span class="text-sm text-gray-500">Cancelled</span>
          <span class="text-sm font-medium text-gray-900"><%= @project_stats[:cancelled] %></span>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Recent Activity -->
<div class="mt-8">
  <div class="bg-white shadow rounded-lg">
    <div class="px-4 py-5 sm:p-6">
      <h4 class="text-lg font-medium text-gray-900 mb-4">Recent Projects</h4>
      <% if @recent_projects.any? %>
        <div class="space-y-3">
          <% @recent_projects.each do |project| %>
            <div class="flex items-center justify-between py-2 border-b border-gray-100 last:border-b-0">
              <div>
                <p class="text-sm font-medium text-gray-900"><%= project.title %></p>
                <p class="text-xs text-gray-500">
                  Client: <%= project.client.email %> | Developer: <%= project.developer.email %>
                </p>
              </div>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                <%= case project.status
                    when 'draft'
                      'bg-gray-100 text-gray-800'
                    when 'active'
                      'bg-green-100 text-green-800'
                    when 'completed'
                      'bg-blue-100 text-blue-800'
                    when 'cancelled'
                      'bg-red-100 text-red-800'
                    end %>">
                <%= project.status.titleize %>
              </span>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-gray-500">No recent projects.</p>
      <% end %>
    </div>
  </div>
</div>

<!-- Admin Actions -->
<div class="mt-8">
  <div class="bg-white shadow rounded-lg">
    <div class="px-4 py-5 sm:p-6">
      <h4 class="text-lg font-medium text-gray-900 mb-4">Admin Actions</h4>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
        <%= link_to "View All Projects", projects_path, class: "inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" %>
        <%= link_to "View All Users", "#", class: "inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" %>
        <%= link_to "View Disputes", "#", class: "inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" %>
        <%= link_to "View Transactions", "#", class: "inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" %>
      </div>
    </div>
  </div>
</div>
