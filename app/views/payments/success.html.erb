<div class="max-w-md mx-auto text-center">
  <div class="bg-white shadow rounded-lg p-6">
    <div class="mb-4">
      <svg class="mx-auto h-12 w-12 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
    </div>
    
    <h3 class="text-lg font-medium text-gray-900 mb-2">Payment Successful!</h3>
    <p class="text-sm text-gray-500 mb-6">
      Your milestone has been funded successfully. You will be redirected to the project page shortly.
    </p>
    
    <div class="flex justify-center">
      <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-blue-600"></div>
    </div>
  </div>
</div>

<script>
  // Redirect after 3 seconds
  setTimeout(function() {
    window.location.href = '<%= project_path(@milestone&.project) %>';
  }, 3000);
</script>
