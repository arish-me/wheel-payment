<div class="bg-white shadow rounded-lg">
  <div class="px-4 py-5 sm:p-6">
    <div class="flex justify-between items-start">
      <div class="flex-1">
        <h3 class="text-2xl font-bold text-gray-900"><%= @project.title %></h3>
        <p class="mt-2 text-gray-600"><%= @project.description %></p>
        
        <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-3">
          <div>
            <dt class="text-sm font-medium text-gray-500">Status</dt>
            <dd class="mt-1 text-sm text-gray-900">
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                <%= case @project.status
                    when 'draft'
                      'bg-gray-100 text-gray-800'
                    when 'active'
                      'bg-green-100 text-green-800'
                    when 'completed'
                      'bg-blue-100 text-blue-800'
                    when 'cancelled'
                      'bg-red-100 text-red-800'
                    end %>">
                <%= @project.status.titleize %>
              </span>
            </dd>
          </div>
          
          <div>
            <dt class="text-sm font-medium text-gray-500">Client</dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @project.client.email %></dd>
          </div>
          
          <div>
            <dt class="text-sm font-medium text-gray-500">Developer</dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @project.developer.email %></dd>
          </div>
        </div>
      </div>
      
      <div class="ml-6 flex space-x-3">
        <% if current_user.client? && @project.client == current_user %>
          <%= link_to edit_project_path(@project), class: "inline-flex items-center px-3 py-2 border border-gray-300 shadow-sm text-sm leading-4 font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" do %>
            <svg class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
            </svg>
            Edit
          <% end %>
        <% end %>
        
        <%= link_to projects_path, class: "inline-flex items-center px-3 py-2 border border-gray-300 shadow-sm text-sm leading-4 font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" do %>
          <svg class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Back
        <% end %>
      </div>
    </div>
  </div>
</div>

<!-- Milestones Section -->
<div class="mt-8">
  <div class="bg-white shadow rounded-lg">
    <div class="px-4 py-5 sm:p-6">
      <div class="flex justify-between items-center mb-6">
        <div>
          <h4 class="text-lg font-medium text-gray-900">Milestones</h4>
          <p class="mt-1 text-sm text-gray-500">
            Track progress and manage payments for each milestone.
          </p>
        </div>
        
        <% if current_user.client? && @project.client == current_user %>
          <button type="button" onclick="document.getElementById('newMilestoneForm').classList.toggle('hidden')" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700">
            <svg class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
            </svg>
            Add Milestone
          </button>
        <% end %>
      </div>

      <!-- New Milestone Form -->
      <% if current_user.client? && @project.client == current_user %>
        <div id="newMilestoneForm" class="hidden mb-6 p-4 bg-gray-50 rounded-lg">
          <%= form_with model: [@project, @new_milestone], local: true, data: { turbo: false, controller: "milestone" }, class: "space-y-4" do |form| %>
            <% if @new_milestone.errors.any? %>
              <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded relative" role="alert">
                <h4 class="font-medium">Please fix the following errors:</h4>
                <ul class="mt-2 list-disc list-inside">
                  <% @new_milestone.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
              <div>
                <%= form.label :title, class: "block text-sm font-medium text-gray-700" %>
                <%= form.text_field :title, class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm", placeholder: "Milestone title (minimum 3 characters)" %>
                <p class="mt-1 text-xs text-gray-500">Enter a clear milestone title</p>
              </div>
              
              <div>
                <%= form.label :amount_cents, "Amount (USD)", class: "block text-sm font-medium text-gray-700" %>
                <%= form.number_field :amount_cents, step: 100, class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm", placeholder: "1000" %>
                <p class="mt-1 text-xs text-gray-500">Amount in cents (e.g., 1000 = $10.00)</p>
              </div>
              
              <div>
                <%= form.label :currency, class: "block text-sm font-medium text-gray-700" %>
                <%= form.select :currency, [['USD', 'USD'], ['EUR', 'EUR'], ['GBP', 'GBP'], ['INR', 'INR']], {}, { class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm" } %>
              </div>
            </div>
            
            <div>
              <%= form.label :description, class: "block text-sm font-medium text-gray-700" %>
              <%= form.text_area :description, rows: 3, minlength: 10, class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm", placeholder: "Describe what this milestone includes (minimum 10 characters)..." %>
              <p class="mt-1 text-xs text-gray-500">Please provide a detailed description (minimum 10 characters)</p>
            </div>
            
            <div class="flex justify-end space-x-3">
              <button type="button" onclick="document.getElementById('newMilestoneForm').classList.add('hidden')" class="inline-flex items-center px-3 py-2 border border-gray-300 shadow-sm text-sm leading-4 font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50">
                Cancel
              </button>
              <%= form.submit "Create Milestone", class: "inline-flex items-center px-3 py-2 border border-transparent text-sm leading-4 font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700", onclick: "console.log('Form submitted')" %>
            </div>
          <% end %>
        </div>
      <% end %>

      <!-- Edit Milestone Forms -->
      <% if current_user.client? && @project.client == current_user %>
        <% @milestones.each do |milestone| %>
          <div id="editMilestoneForm<%= milestone.id %>" class="hidden mb-6 p-4 bg-gray-50 rounded-lg">
            <%= form_with model: [@project, milestone], local: true, data: { turbo: false }, class: "space-y-4" do |form| %>
              <% if milestone.errors.any? %>
                <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded relative" role="alert">
                  <h4 class="font-medium">Please fix the following errors:</h4>
                  <ul class="mt-2 list-disc list-inside">
                    <% milestone.errors.full_messages.each do |message| %>
                      <li><%= message %></li>
                    <% end %>
                  </ul>
                </div>
              <% end %>
              <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
                <div>
                  <%= form.label :title, class: "block text-sm font-medium text-gray-700" %>
                  <%= form.text_field :title, class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm", placeholder: "Milestone title (minimum 3 characters)" %>
                  <p class="mt-1 text-xs text-gray-500">Enter a clear milestone title</p>
                </div>
                
                <div>
                  <%= form.label :amount_cents, "Amount (USD)", class: "block text-sm font-medium text-gray-700" %>
                  <%= form.number_field :amount_cents, step: 100, class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm", placeholder: "1000" %>
                  <p class="mt-1 text-xs text-gray-500">Amount in cents (e.g., 1000 = $10.00)</p>
                </div>
                
                <div>
                  <%= form.label :currency, class: "block text-sm font-medium text-gray-700" %>
                  <%= form.select :currency, [['USD', 'USD'], ['EUR', 'EUR'], ['GBP', 'GBP'], ['INR', 'INR']], {}, { class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm" } %>
                </div>
              </div>
              
              <div>
                <%= form.label :description, class: "block text-sm font-medium text-gray-700" %>
                <%= form.text_area :description, rows: 3, minlength: 10, class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm", placeholder: "Describe what this milestone includes (minimum 10 characters)..." %>
                <p class="mt-1 text-xs text-gray-500">Please provide a detailed description (minimum 10 characters)</p>
              </div>
              
              <div class="flex justify-end space-x-3">
                <button type="button" onclick="toggleEditForm(<%= milestone.id %>)" class="inline-flex items-center px-3 py-2 border border-gray-300 shadow-sm text-sm leading-4 font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50">
                  Cancel
                </button>
                <%= form.submit "Update Milestone", class: "inline-flex items-center px-3 py-2 border border-transparent text-sm leading-4 font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700" %>
              </div>
            <% end %>
          </div>
        <% end %>
      <% end %>

      <!-- Dispute Forms -->
      <% @milestones.each do |milestone| %>
        <% if milestone.funded? || milestone.completed? %>
          <div id="disputeForm<%= milestone.id %>" class="hidden mb-6 p-4 bg-red-50 rounded-lg">
            <%= form_with model: [@project, milestone, milestone.disputes.build], local: true, data: { turbo: false }, class: "space-y-4" do |form| %>
              <div class="flex items-center space-x-2 mb-4">
                <svg class="h-5 w-5 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z" />
                </svg>
                <h4 class="text-lg font-medium text-red-900">Raise Dispute for "<%= milestone.title %>"</h4>
              </div>
              
              <div>
                <%= form.label :reason, "Dispute Reason", class: "block text-sm font-medium text-gray-700" %>
                <%= form.text_area :reason, rows: 4, minlength: 10, class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-red-500 focus:border-red-500 sm:text-sm", placeholder: "Please explain the reason for this dispute (minimum 10 characters)..." %>
                <p class="mt-1 text-xs text-gray-500">Provide a detailed explanation of the issue</p>
              </div>
              
              <div class="flex justify-end space-x-3">
                <button type="button" onclick="toggleDisputeForm(<%= milestone.id %>)" class="inline-flex items-center px-3 py-2 border border-gray-300 shadow-sm text-sm leading-4 font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50">
                  Cancel
                </button>
                <%= form.submit "Submit Dispute", class: "inline-flex items-center px-3 py-2 border border-transparent text-sm leading-4 font-medium rounded-md text-white bg-red-600 hover:bg-red-700" %>
              </div>
            <% end %>
          </div>
        <% end %>
      <% end %>

      <!-- Review Forms -->
      <% @milestones.each do |milestone| %>
        <% if milestone.released? && !milestone.review.present? %>
          <div id="reviewForm<%= milestone.id %>" class="hidden mb-6 p-4 bg-blue-50 rounded-lg">
            <%= form_with model: [@project, milestone, milestone.build_review], local: true, data: { turbo: false }, class: "space-y-4" do |form| %>
              <div class="flex items-center space-x-2 mb-4">
                <svg class="h-5 w-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
                <h4 class="text-lg font-medium text-blue-900">Review "<%= milestone.title %>"</h4>
              </div>
              
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Rating</label>
                <div class="flex items-center space-x-1">
                  <% 5.times do |i| %>
                    <button type="button" onclick="setRating(<%= i + 1 %>)" class="rating-star text-2xl text-gray-300 hover:text-yellow-400" data-rating="<%= i + 1 %>">
                      ★
                    </button>
                  <% end %>
                </div>
                <input type="hidden" name="review[rating]" id="rating-input" value="5">
              </div>
              
              <div>
                <%= form.label :comment, "Review Comment", class: "block text-sm font-medium text-gray-700" %>
                <%= form.text_area :comment, rows: 4, minlength: 10, class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm", placeholder: "Share your experience with this milestone (minimum 10 characters)..." %>
                <p class="mt-1 text-xs text-gray-500">Provide detailed feedback about the work</p>
              </div>
              
              <div class="flex justify-end space-x-3">
                <button type="button" onclick="toggleReviewForm(<%= milestone.id %>)" class="inline-flex items-center px-3 py-2 border border-gray-300 shadow-sm text-sm leading-4 font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50">
                  Cancel
                </button>
                <%= form.submit "Submit Review", class: "inline-flex items-center px-3 py-2 border border-transparent text-sm leading-4 font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700" %>
              </div>
            <% end %>
          </div>
        <% end %>
      <% end %>

      <!-- Milestones List -->
      <% if @milestones.any? %>
        <div class="space-y-4">
          <% @milestones.each do |milestone| %>
            <div class="border border-gray-200 rounded-lg p-4">
              <div class="flex items-center justify-between">
                <div class="flex-1">
                  <div class="flex items-center space-x-3">
                    <h5 class="text-lg font-medium text-gray-900"><%= milestone.title %></h5>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                      <%= case milestone.status
                          when 'pending'
                            'bg-gray-100 text-gray-800'
                          when 'funded'
                            'bg-yellow-100 text-yellow-800'
                          when 'completed'
                            'bg-blue-100 text-blue-800'
                          when 'released'
                            'bg-green-100 text-green-800'
                          when 'refunded'
                            'bg-red-100 text-red-800'
                          end %>">
                      <%= milestone.status.titleize %>
                    </span>
                  </div>
                  
                  <p class="mt-1 text-sm text-gray-600"><%= milestone.description %></p>
                  
                  <div class="mt-2 flex items-center space-x-6 text-sm text-gray-500">
                    <span>Amount: $<%= number_with_precision(milestone.amount_cents / 100.0, precision: 2) %></span>
                    <span>Currency: <%= milestone.currency %></span>
                    <span>Created: <%= milestone.created_at.strftime("%B %d, %Y") %></span>
                    <% if milestone.transactions.any? %>
                      <span>Transactions: <%= milestone.transactions.count %></span>
                    <% end %>
                  </div>
                  
                  <!-- Reviews Section -->
                  <% if milestone.released? %>
                    <% if milestone.review.present? %>
                      <div class="mt-3 p-3 bg-gray-50 rounded-lg">
                        <div class="flex items-center space-x-2">
                          <div class="flex items-center">
                            <% 5.times do |i| %>
                              <svg class="h-4 w-4 <%= i < milestone.review.rating ? 'text-yellow-400' : 'text-gray-300' %>" fill="currentColor" viewBox="0 0 20 20">
                                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                              </svg>
                            <% end %>
                          </div>
                          <span class="text-sm text-gray-600">by <%= milestone.review.reviewer.email %></span>
                        </div>
                        <p class="mt-2 text-sm text-gray-700"><%= milestone.review.comment %></p>
                      </div>
                    <% elsif current_user.client? && @project.client == current_user %>
                      <button type="button" onclick="toggleReviewForm(<%= milestone.id %>)" class="mt-3 inline-flex items-center px-3 py-1 border border-transparent text-xs font-medium rounded text-blue-600 bg-blue-100 hover:bg-blue-200">
                        Write Review
                      </button>
                    <% end %>
                  <% end %>
                </div>
                
                <div class="flex items-center space-x-2">
                  <% if current_user.client? && @project.client == current_user %>
                    <% if milestone.pending? %>
                      <%= link_to "Fund with Stripe", payments_create_checkout_session_path(milestone_id: milestone.id), class: "inline-flex items-center px-3 py-1 border border-transparent text-xs font-medium rounded text-white bg-green-600 hover:bg-green-700" %>
                    <% elsif milestone.completed? %>
                      <%= button_to release_project_milestone_path(@project, milestone), method: :post, class: "inline-flex items-center px-3 py-1 border border-transparent text-xs font-medium rounded text-white bg-blue-600 hover:bg-blue-700" do %>
                        Release
                      <% end %>
                    <% elsif milestone.funded? %>
                      <%= button_to refund_project_milestone_path(@project, milestone), method: :post, class: "inline-flex items-center px-3 py-1 border border-transparent text-xs font-medium rounded text-white bg-red-600 hover:bg-red-700" do %>
                        Refund
                      <% end %>
                    <% end %>
                  <% end %>
                  
                  <% if current_user.developer? && @project.developer == current_user %>
                    <% if milestone.funded? %>
                      <%= button_to complete_project_milestone_path(@project, milestone), method: :post, class: "inline-flex items-center px-3 py-1 border border-transparent text-xs font-medium rounded text-white bg-green-600 hover:bg-green-700" do %>
                        Mark Complete
                      <% end %>
                    <% end %>
                  <% end %>
                  
                  <!-- Dispute Button -->
                  <% if milestone.funded? || milestone.completed? %>
                    <% if milestone.disputes.open.any? %>
                      <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-red-100 text-red-800">
                        Dispute Open
                      </span>
                    <% else %>
                      <button type="button" onclick="toggleDisputeForm(<%= milestone.id %>)" class="inline-flex items-center px-3 py-1 border border-transparent text-xs font-medium rounded text-red-600 bg-red-100 hover:bg-red-200">
                        Raise Dispute
                      </button>
                    <% end %>
                  <% end %>
                  
                  <% if current_user.client? && @project.client == current_user %>
                    <button type="button" onclick="toggleEditForm(<%= milestone.id %>)" class="text-blue-600 hover:text-blue-800 text-xs font-medium">Edit</button>
                  <% end %>
                  
                  <% if Rails.env.development? && milestone.pending? && milestone.transactions.any? %>
                    <%= link_to "Test Webhook", test_webhook_path(milestone), class: "text-green-600 hover:text-green-800 text-xs font-medium", data: { turbo: false } %>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="text-center py-8">
          <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
          </svg>
          <h3 class="mt-2 text-sm font-medium text-gray-900">No milestones</h3>
          <p class="mt-1 text-sm text-gray-500">
            <%= current_user.client? && @project.client == current_user ? 'Get started by creating a milestone.' : 'No milestones have been created yet.' %>
          </p>
        </div>
      <% end %>
    </div>
  </div>
</div>
